{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "arquivos antigos recuperados",
      "backup_react_version"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "rules": "firestore.rules",
  "storage": {
    "rules": "storage.rules"
  }
}
