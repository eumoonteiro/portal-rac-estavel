rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Declarações - read para todos autenticados, write para coordenadores
    match /declaracoes/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Carteirinhas - read para todos autenticados, write para coordenadores
    match /carteirinhas/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
